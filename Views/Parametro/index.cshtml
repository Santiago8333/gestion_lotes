@{
    ViewData["Title"] = "Parámetros";
}
<div id="app">
<div class="card mb-3 bg-light">
    <div class="card-body">
        <h1>Parámetros</h1>
        <p class="text-muted">
            Porcentajes aplicados al emitir cada recibo. Solo el administrador puede modificarlos.
            El cambio afecta a los recibos que se creen de ahora en adelante.
        </p>
        <form v-on:submit.prevent="ModificarParametros" id="formParametros" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" name="id_parametros" v-model="parametros.id_parametros">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="honorarios" class="form-label">Honorarios CMCPSL (%)</label>
                    <div class="input-group">
                        <input type="number" step="0.01" min="0" max="100"
                               class="form-control" id="honorarios" name="honorarios"
                               v-model="parametros.honorarios" required>
                        <span class="input-group-text">%</span>
                    </div>
                    <div class="invalid-feedback">El porcentaje de honorarios es obligatorio (0 a 100).</div>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="sellado" class="form-label">Sellado DPIP (%)</label>
                    <div class="input-group">
                        <input type="number" step="0.001" min="0" max="100"
                               class="form-control" id="sellado" name="sellado"
                               v-model="parametros.sellado" required>
                        <span class="input-group-text">%</span>
                    </div>
                    <div class="invalid-feedback">El porcentaje de sellado es obligatorio (0 a 100).</div>
                </div>
                <div class="col-12 mb-3 text-end">
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                </div>
            </div>
        </form>
    </div>
</div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto">Sistema</strong>
      <small class="text-muted">justo ahora</small>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Cerrar"></button>
    </div>
    <div class="toast-body">
      @TempData["Mensaje"]
    </div>
  </div>
</div>

@section Scripts {
<script>
const appConfig = {
    data() {
        return {
            parametros: {
                id_parametros: 0,
                honorarios: 0,
                sellado: 0
            },
            toastBS: null
        };
    },
    mounted() {
        this.obtenerParametros();
        const toastEl = document.getElementById('successToast');
        if (toastEl) this.toastBS = new bootstrap.Toast(toastEl);
    },
    methods: {
        async obtenerParametros() {
            try {
                const response = await fetch('/api/parametros');
                if (!response.ok) {
                    throw new Error('Error al obtener los parámetros');
                }
                const data = await response.json();
                this.parametros = data;
            } catch (error) {
                console.error('Hubo un problema:', error);
                this.mostrarToast('No se pudieron cargar los parámetros.');
            }
        },
        async ModificarParametros() {
            const form = document.getElementById('formParametros');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }
            form.classList.add('was-validated');

            try {
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';

                const cuerpo = {
                    id_parametros: this.parametros.id_parametros,
                    honorarios: parseFloat(this.parametros.honorarios),
                    sellado: parseFloat(this.parametros.sellado)
                };

                const response = await fetch('/api/parametros', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(cuerpo)
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.mensaje || 'Error al procesar la solicitud.');
                }

                this.mostrarToast(data.mensaje);
                this.obtenerParametros();
                form.classList.remove('was-validated');
            } catch (error) {
                console.error('Error al modificar los parámetros:', error);
                this.mostrarToast(error.message);
            }
        },
        mostrarToast(mensaje) {
            const toastBody = document.querySelector('#successToast .toast-body');
            if (toastBody) toastBody.textContent = mensaje;
            if (this.toastBS) this.toastBS.show();
        }
    }
};

const app = Vue.createApp(appConfig);
window.appInstance = app.mount('#app');
</script>
}
